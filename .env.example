# LLM API Configuration (via claude-code-bridge)
LLM_BASE_URL=/api/llm/v1
LLM_API_KEY=local-bridge
LLM_MODEL=claude-sonnet-4-6

# LLM Proxy Target (Vite dev proxy → claude-code-bridge)
LLM_PROXY_TARGET=http://localhost:8080

# Bocha Search API
BOCHA_API_KEY=your-bocha-api-key

# EastMoney API
EASTMONEY_APIKEY=your-eastmoney-api-key

# Optional: Disable HMR for stability
# DISABLE_HMR=true
